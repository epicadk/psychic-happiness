# Copy to .env and fill in. Loaded by the Supabase CLI for local function dev:
#   supabase functions serve --env-file ./.env
# In production, set these with `supabase secrets set KEY=value`.

# AI photo food logging (ai-food-log)
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-sonnet-4-6
AI_FOOD_MODEL=

# Food search fallback (food-lookup)
NUTRITIONIX_APP_ID=
NUTRITIONIX_APP_KEY=

# Strava webhooks (strava-webhook)
STRAVA_VERIFY_TOKEN=
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY are injected by the
# Edge runtime automatically — no need to set them here.
